<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilTargetEpc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="@string/radar_target_epc"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_marginEnd="6dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editTargetEpc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textVisiblePassword|textNoSuggestions"
                android:text="@string/example_code"
                android:textSize="16sp"
                android:fontFamily="monospace" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPaste"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            app:icon="@drawable/ic_paste"
            app:iconTint="@color/md_theme_primary"
            android:contentDescription="@string/radar_paste_description" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="10dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnToggleRadar"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="@string/radar_start"
            android:textSize="14sp"
            android:textAllCaps="false"
            app:icon="@drawable/ic_rfid"
            app:iconGravity="textStart"
            app:iconPadding="6dp"
            app:cornerRadius="10dp"
            style="@style/Widget.Material3.Button"
            android:layout_marginEnd="8dp" />

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggleRadarPower"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true"
            app:checkedButton="@+id/btnPowerHigh">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPowerLow"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="20"
                android:textSize="11sp"
                android:minWidth="0dp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPowerMedium"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="25"
                android:textSize="11sp"
                android:minWidth="0dp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPowerHigh"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="30"
                android:textSize="11sp"
                android:minWidth="0dp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp" />

        </com.google.android.material.button.MaterialButtonToggleGroup>
    </LinearLayout>

    <!-- Tag List Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingBottom="4dp">
        <TextView
            android:layout_width="30dp"
            android:layout_height="wrap_content"
            android:text="#"
            android:textSize="11sp"
            android:textColor="@color/md_theme_onSurfaceVariant" />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="EPC / SIGNAL INTENSITY"
            android:textSize="11sp"
            android:textColor="@color/md_theme_onSurfaceVariant" />
        <TextView
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:text="dBm"
            android:textSize="11sp"
            android:gravity="end"
            android:textColor="@color/md_theme_onSurfaceVariant" />
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        app:cardCornerRadius="12dp"
        app:cardElevation="1dp"
        app:strokeColor="@color/outline"
        app:strokeWidth="1dp">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <LinearLayout
                android:id="@+id/tagsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </ScrollView>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="100dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        android:layout_marginTop="8dp"
        app:strokeWidth="0dp">

        <com.trackstudio.rfidmanager.RadarGraphView
            android:id="@+id/radarGraph"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="8dp" />
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
