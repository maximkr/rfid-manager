<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilTargetEpc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="@string/radar_target_epc"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_marginEnd="6dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editTargetEpc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textVisiblePassword|textNoSuggestions"
                android:text="@string/example_code"
                android:textSize="16sp"
                android:fontFamily="monospace" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPaste"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            app:icon="@drawable/ic_paste"
            app:iconTint="@color/md_theme_primary"
            android:contentDescription="@string/radar_paste_description" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="10dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnToggleRadar"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="@string/radar_start"
            android:textSize="14sp"
            android:textAllCaps="false"
            app:icon="@drawable/ic_rfid"
            app:iconGravity="textStart"
            app:iconPadding="6dp"
            app:cornerRadius="10dp"
            style="@style/Widget.Material3.Button" />
    </LinearLayout>



    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        android:layout_marginTop="8dp"
        app:strokeWidth="0dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <com.trackstudio.rfidmanager.RadarGraphView
                android:id="@+id/radarGraph"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="8dp" />

            <TextView
                android:id="@+id/tvOverlayScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_marginTop="24dp"
                android:layout_marginEnd="90dp"
                android:text="-90.0 dBm"
                android:textSize="36sp"
                android:textColor="@color/md_theme_primary"
                android:textStyle="bold"
                android:visibility="gone" />
        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
